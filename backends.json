{
  "servers": {
    "sequentialthinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "type": "stdio"
    },
    "taskmaster-ai": {
      "command": "npx",
      "args": [
        "-y",
        "-p",
        "@modelcontextprotocol/sdk@1.17.2",
        "-p",
        "fastmcp@3.23.0",
        "-p",
        "task-master-ai",
        "task-master-ai"
      ],
      "env": {
        "TASK_MASTER_TOOLS": "standard",
        "TASK_MASTER_ALLOW_METADATA_UPDATES": "true"
      }
    },
    "my-mcp-server": {
      "type": "stdio",
      "command": "my_mcp_server",
      "args": []
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp"
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "a11y": {
      "command": "npx",
      "args": [
        "a11y-mcp"
      ],
      "disabled": false,
      "autoApprove": []
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "csv-editor": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/santoshray02/csv-editor",
        "csv-editor"
      ]
    },
    "html-to-markdown": {
      "command": "npx",
      "args": [
        "html-to-markdown-mcp"
      ]
    },
    "json-mcp-filter": {
      "command": "npx",
      "args": [
        "-y",
        "json-mcp-filter@latest"
      ]
    },
    "large-file": {
      "command": "npx",
      "args": [
        "-y",
        "@willianpinho/large-file-mcp"
      ]
    },
    "burp": {
      "command": "java",
      "args": [
        "-jar",
        "/home/ronnas/mcp-proxy.jar",
        "--sse-url",
        "http://127.0.0.1:9876/"
      ]
    },
    "gcloud": {
      "command": "npx",
      "args": [
        "-y",
        "@google-cloud/gcloud-mcp"
      ]
    }
  }
}